<?xml version="1.0" encoding="UTF-8"?>
<!--
    log4j2.xml — Configuración de logging asíncrono
    Modo ALL_ASYNC: todos los loggers son async por defecto (requiere LMAX Disruptor en classpath).
    Ninguna llamada a log.xxx() bloquea el hilo del servlet.
-->
<Configuration>

    <Properties>
        <Property name="LOG_DIR">/home/javi/logs</Property>
        <Property name="APP_LOG">${LOG_DIR}/app.log</Property>
        <Property name="ERROR_LOG">${LOG_DIR}/error.log</Property>
        <Property name="PATTERN_APP">%d{yyyy-MM-dd HH:mm:ss} | %m%n</Property>
        <Property name="ENV">${sys:env:-DEV}</Property>
    </Properties>

    <Appenders>

        <Console name="Console">
            <PatternLayout pattern="${PATTERN_APP}"/>
        </Console>

        <Routing name="appender202">
            <Routes pattern="$${ctx:requestId}">
                <Route>
                    <File name="File-${ctx:requestId}" fileName="${LOG_DIR}/xml-202-${ctx:requestId}.log" append="true">
                        <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} | %m%n"/>
                    </File>
                </Route>
            </Routes>
        </Routing>

        <Routing name="appender3">
            <Routes pattern="$${ctx:requestId}">
                <Route>
                    <File name="File-${ctx:requestId}" fileName="${LOG_DIR}/xml-3-${ctx:requestId}.log" append="true">
                        <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} | %m%n"/>
                    </File>
                </Route>
            </Routes>
        </Routing>


        <!-- ── Log principal de la aplicación (rolling diario + por tamaño) ── -->
        <RollingFile name="AppFile"
                     fileName="${APP_LOG}"
                     filePattern="${LOG_DIR}/app-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${PATTERN_APP}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- ── Error log separado para facilitar alertas ── -->
        <RollingFile name="ErrorFile"
                     fileName="${ERROR_LOG}"
                     filePattern="${LOG_DIR}/error-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${PATTERN_APP}"/>
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

    </Appenders>

    <Loggers>

        <AsyncRoot level="INFO">
            <AppenderRef ref="AppFile"/>
            <AppenderRef ref="ErrorFile"/>
            <SystemPropertyArbiter propertyName="env" propertyValue="DEV">
                <AppenderRef ref="Console"/>
            </SystemPropertyArbiter>
        </AsyncRoot>


        <AsyncLogger name="PRERESERVA"
                     level="INFO"
                     additivity="false">
            <AppenderRef ref="appender202"/>
        </AsyncLogger>

        <AsyncLogger name="CONFIRM"
                     level="INFO"
                     additivity="false">
            <AppenderRef ref="appender3"/>
        </AsyncLogger>

    </Loggers>

</Configuration>
